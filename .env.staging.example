# ─── GrainGuard Staging Environment ──────────────────────────
# Copy to .env.staging and fill in real values

# ── Auth0 ────────────────────────────────────────────────────
AUTH0_DOMAIN=your-staging-tenant.auth0.com
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=
JWKS_URL=https://your-staging-tenant.auth0.com/.well-known/jwks.json
JWT_ISSUER=https://your-staging-tenant.auth0.com/
JWT_AUDIENCE=https://api.staging.grainguard.io

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Postgres ─────────────────────────────────────────────────
DATABASE_URL=postgresql://grainguard:CHANGEME@postgres-staging:5432/grainguard?sslmode=require
DATABASE_READ_URL=postgresql://grainguard:CHANGEME@postgres-read-staging:5432/grainguard?sslmode=require

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis-staging:6379
REDIS_ADDR=redis-staging:6379

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BROKERS=kafka-staging-1:9092,kafka-staging-2:9092,kafka-staging-3:9092

# ── Cassandra ────────────────────────────────────────────────
CASSANDRA_HOSTS=cassandra-staging-1,cassandra-staging-2,cassandra-staging-3
CASSANDRA_KEYSPACE=grainguard_telemetry

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_URL=amqp://grainguard:CHANGEME@rabbitmq-staging:5672/grainguard

# ── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch-staging:9200

# ── Frontend ─────────────────────────────────────────────────
VITE_AUTH0_DOMAIN=your-staging-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://api.staging.grainguard.io
VITE_BFF_URL=https://api.staging.grainguard.io/graphql
VITE_GATEWAY_URL=https://api.staging.grainguard.io
DASHBOARD_URL=https://staging.grainguard.io

# ── Ingest Service ───────────────────────────────────────────
INGEST_PORT=3001
KAFKA_TOPIC=telemetry.events
KAFKA_BATCH_SIZE=200
KAFKA_BATCH_TIMEOUT_MS=5

# ── Observability ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
SENTRY_DSN=

# ── Misc ─────────────────────────────────────────────────────
NODE_ENV=staging
ALLOWED_ORIGINS=https://staging.grainguard.io
