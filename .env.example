# ─────────────────────────────────────────────────────────────────
# GrainGuard — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Auth0 — Frontend SPA (Vite) ───────────────────────────────────
VITE_AUTH0_DOMAIN=<your-tenant>.us.auth0.com
VITE_AUTH0_CLIENT_ID=<your-spa-client-id>
VITE_AUTH0_AUDIENCE=https://api.grainguard.com

# ── Auth0 — Backend M2M (gateway / SSO routes) ────────────────────
AUTH0_DOMAIN=<your-tenant>.us.auth0.com
AUTH0_CLIENT_ID=<your-m2m-client-id>
AUTH0_CLIENT_SECRET=<your-m2m-client-secret>
AUTH0_AUDIENCE=https://api.grainguard.com
AUTH0_MANAGEMENT_AUDIENCE=https://<your-tenant>.us.auth0.com/api/v2/
AUTH0_MANAGEMENT_CLIENT_ID=<your-m2m-client-id>
AUTH0_MANAGEMENT_CLIENT_SECRET=<your-m2m-client-secret>

# ── Stripe ────────────────────────────────────────────────────────
# Use sk_test_... for development, sk_live_... for production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Email (Resend) ────────────────────────────────────────────────
# Required for team invite emails, alert notifications, and data exports.
# Get a free API key at https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=GrainGuard <noreply@yourdomain.com>

# ── Slack (optional) ──────────────────────────────────────────────
# Used by Grafana alerting. Leave empty to disable.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Database (optional overrides — docker-compose sets these) ─────
# WRITE_DB_HOST=postgres
# WRITE_DB_PORT=5432
# WRITE_DB_NAME=grainguard
# WRITE_DB_USER=postgres
# WRITE_DB_PASSWORD=postgres
