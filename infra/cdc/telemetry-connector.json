{
  "name": "grainguard-postgres-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "tasks.max": "1",

    "database.hostname": "postgres",
    "database.port": "5432",
    "database.user": "postgres",
    "database.password": "postgres",
    "database.dbname": "grainguard",

    "topic.prefix": "grainguard",

    "plugin.name": "pgoutput",

    "slot.name": "grainguard_slot",
    "publication.name": "grainguard_pub",

    "table.include.list": "public.devices,public.telemetry_readings",

    "tombstones.on.delete": "false",

    "schema.history.internal.kafka.bootstrap.servers": "kafka:9092",
    "schema.history.internal.kafka.topic": "grainguard.schema-history"
  }
}